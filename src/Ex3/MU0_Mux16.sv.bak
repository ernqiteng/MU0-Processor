// COMP12111 Exercise 3 - MU0_Mux16 
// Version 2024. P W Nutter
// 
// 2-to-1 16-bit MUX implementation
//
// Implement using behavioural Verilog
//
// Comments:
// creates 12 bit multiplexer to be used in the datapath of the MU0 processor
// Updated November 2025
// By Ern Qi Teng
//

// Do not touch the following line it is required for simulation 
`timescale 1ns/100ps
 

// module definition

module MU0_Mux16 (
input  logic  [15:0] A, //inputs
input  logic  [15:0] B, 
input  logic         S, //control signal to select inputs
output logic  [15:0]  Q
);


// Combinatorial logic for 2to1 multiplexor
// S is select, A channel0, B channel1

always_comb
begin
	case(S)
		0: Q = A;
		1: Q = B;
		default: Q = 16'hxxx;
	endcase
end
endmodule 
 
